NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tcc_idea_builder
DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5432/tcc_idea_builder_test
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash
RESEND_API_KEY=your-resend-api-key
SMTP_FROM_NAME=TCC Idea Builder
SMTP_FROM_EMAIL=contato@tccideabuilder.online
EMAIL_ENABLED=true
EMAIL_RETRY_MAX=3
EMAIL_RETRY_BASE_MS=30000
